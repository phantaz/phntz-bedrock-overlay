#!/usr/bin/env bash

set -Eeuo pipefail

OVERLAY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="${OVERLAY_DIR}/templates"
COMPOSER_REPOSITORY="https://api.phntz.com/packages.json"
THEME_STAGING=''

cleanup() {
  if [[ -n "$THEME_STAGING" && -d "$THEME_STAGING" ]]; then
    rm -rf -- "$THEME_STAGING"
  fi
}

trap cleanup EXIT

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

ask() {
  local prompt="$1"
  local default="${2:-}"
  local answer

  if [[ -n "$default" ]]; then
    read -r -p "${prompt} [${default}]: " answer
    printf '%s' "${answer:-$default}"
  else
    read -r -p "${prompt}: " answer
    printf '%s' "$answer"
  fi
}

confirm() {
  local prompt="$1"
  local default="${2:-yes}"
  local hint='y/N'
  local answer

  [[ "$default" == 'yes' ]] && hint='Y/n'
  read -r -p "${prompt} (${hint}): " answer
  answer="${answer:-$default}"

  [[ "$answer" =~ ^([yY]|[yY][eE][sS])$ ]]
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g'
}

append_once() {
  local source="$1"
  local destination="$2"
  local marker="$3"

  touch "$destination"

  if ! grep -Fq "$marker" "$destination"; then
    cat "$source" >> "$destination"
  fi
}

set_env() {
  local key="$1"
  local value="$2"
  local file="$3"
  local escaped="${value//\\/\\\\}"
  local temporary

  escaped="${escaped//\'/\\\'}"
  temporary="$(mktemp)"
  awk -v key="$key" '$0 !~ "^[[:space:]]*" key "=" { print }' "$file" > "$temporary"
  printf "%s='%s'\n" "$key" "$escaped" >> "$temporary"
  mv "$temporary" "$file"
}

random_secret() {
  openssl rand -base64 48 | tr -d '\n'
}

require_package() {
  local package="$1"
  local default="${2:-yes}"

  if confirm "Install ${package}?" "$default"; then
    PACKAGES+=("$package")
  fi
}

validate_generated_theme() {
  local directory="$1"

  [[ -f "$directory/.phntz-child-theme" ]] \
    || fail "Refusing to use a theme that was not generated by this overlay: ${directory}"
  [[ -f "$directory/style.css" ]] \
    || fail "Generated child theme stylesheet is missing: ${directory}/style.css"
  grep -Eq '^[[:space:]]*Template:[[:space:]]+bricks[[:space:]]*$' "$directory/style.css" \
    || fail "Generated theme is not a Bricks child theme: ${directory}"
  grep -Eq '^[[:space:]]*Update URI:[[:space:]]+https://phntz\.dev/themes/' "$directory/style.css" \
    || fail "Generated theme is not protected from WordPress.org updates: ${directory}"
}

if [[ "${1:-}" == '--help' || "${1:-}" == '-h' ]]; then
  cat <<'HELP'
Apply the Phantaz Bricks layer to an existing, clean Roots Bedrock project.

Usage:
  cd /path/to/bedrock
  /path/to/phntz-bedrock-overlay/apply

Run this only after `ddev composer create-project roots/bedrock` locally or
`composer create-project roots/bedrock` on a regular server.
HELP
  exit 0
fi

[[ -f composer.json ]] || fail 'Run this command from the Bedrock project root.'
[[ -f config/application.php ]] || fail 'config/application.php was not found.'
[[ -d web/app/themes ]] || fail 'web/app/themes was not found.'
grep -Fq 'roots/bedrock' composer.json || fail 'composer.json does not look like a standard Roots Bedrock project.'

command -v curl >/dev/null 2>&1 || fail 'curl is required.'
command -v openssl >/dev/null 2>&1 || fail 'openssl is required.'

IS_DDEV='no'
COMPOSER_COMMAND=()
WP_COMMAND=()

if [[ -f .ddev/config.yaml ]]; then
  command -v ddev >/dev/null 2>&1 || fail 'This is a DDEV project, but ddev was not found.'
  ddev describe >/dev/null 2>&1 || fail 'Start the DDEV project before applying the overlay.'
  IS_DDEV='yes'
  COMPOSER_COMMAND=(ddev composer)
  # DDEV may otherwise inject --path=$DDEV_DOCROOT (web), while the
  # Composer-installed WordPress core in Bedrock lives in web/wp.
  WP_COMMAND=(ddev wp --path=/var/www/html/web/wp --skip-themes)
else
  command -v composer >/dev/null 2>&1 || fail 'Composer was not found.'
  COMPOSER_COMMAND=(composer)

  if command -v wp >/dev/null 2>&1; then
    WP_COMMAND=(wp --path="$PWD/web/wp" --skip-themes)
  fi
fi

composer_version_output="$("${COMPOSER_COMMAND[@]}" --version 2>&1)"
if ! grep -Eq 'Composer version 2\.' <<< "$composer_version_output"; then
  fail 'Composer 2 is required.'
fi

composer_token="${WP_BOX_COMPOSER_TOKEN:-}"
if [[ -z "$composer_token" ]]; then
  read -r -s -p 'WP Box Composer bearer token: ' composer_token
  printf '\n'
fi
[[ -n "$composer_token" ]] || fail 'WP Box Composer bearer token is required.'

repository_json="$(curl -fsSL --max-time 15 -H "Authorization: Bearer ${composer_token}" "$COMPOSER_REPOSITORY")" \
  || fail 'Could not download the Phantaz Composer repository metadata.'

if ! grep -q '"metadata-url"' <<< "$repository_json" || ! grep -q '"packages"[[:space:]]*:[[:space:]]*{}' <<< "$repository_json"; then
  fail 'wp-box must expose Composer 2 P2 metadata: empty packages, metadata-url, and available-packages.'
fi

default_slug="$(slugify "$(basename "$PWD")")"
[[ -n "$default_slug" ]] || default_slug='project'
project_title="$(ask 'Project/site name' "$(printf '%s' "$default_slug" | tr '-' ' ')")"
suggested_slug="$(slugify "$project_title")"
[[ -n "$suggested_slug" ]] || suggested_slug="$default_slug"
project_slug="$(slugify "$(ask 'Project slug' "$suggested_slug")")"
[[ -n "$project_slug" ]] || fail 'The slug must contain latin letters or numbers.'
theme_slug="${project_slug}-bricks-child"
theme_dir="web/app/themes/${theme_slug}"
[[ ! -e "$theme_dir" ]] || fail "Theme already exists: ${theme_dir}"

PACKAGES=('phantaz/bricks:*')
printf '\nBricks is required. Select the remaining packages.\n'
require_package 'phantaz/advanced-custom-fields-pro:*'
require_package 'phantaz/happyfiles-pro:*'
require_package 'phantaz/bricksforge:*'
require_package 'phantaz/perfmatters:*'

if confirm 'Install SEOPress PRO (Free is installed as its dependency)?' 'yes'; then
  PACKAGES+=('phantaz/wp-seopress-pro:*')
fi

require_package 'phantaz/motionpage:*' 'no'

printf '\nConfiguring Composer...\n'
"${COMPOSER_COMMAND[@]}" config --auth bearer.api.phntz.com "$composer_token"
"${COMPOSER_COMMAND[@]}" config repositories.wp-box composer "$COMPOSER_REPOSITORY"
"${COMPOSER_COMMAND[@]}" require --no-update "${PACKAGES[@]}"

printf '\nApplying Bedrock configuration...\n'
install -m 0644 "$TEMPLATE_DIR/config/project.php" config/project.php

if ! grep -Fq "config/project.php" config/application.php; then
  sed -i.bak "/Config::apply();/i\\
require_once __DIR__ . '/project.php';\\
" config/application.php
  rm -f config/application.php.bak
fi

[[ -f .env ]] || cp .env.example .env
append_once "$TEMPLATE_DIR/env.append" .env.example '# Project runtime settings'
append_once "$TEMPLATE_DIR/env.append" .env '# Project runtime settings'
append_once "$TEMPLATE_DIR/gitignore.append" .gitignore '# Composer-installed Bricks parent theme'

set_env 'WP_MEMORY_LIMIT' '256M' .env
set_env 'WP_MAX_MEMORY_LIMIT' '512M' .env

if [[ "$IS_DDEV" == 'no' ]]; then
  printf '\nProduction environment values\n'
  db_name="$(ask 'Database name')"
  db_user="$(ask 'Database user')"
  read -r -s -p 'Database password: ' db_password
  printf '\n'
  db_host="$(ask 'Database host' 'localhost')"
  wp_home="$(ask 'Public site URL (https://example.com)')"

  [[ -n "$db_name" && -n "$db_user" && -n "$db_password" && -n "$wp_home" ]] \
    || fail 'Database name, user, password, and site URL are required.'

  set_env 'DB_NAME' "$db_name" .env
  set_env 'DB_USER' "$db_user" .env
  set_env 'DB_PASSWORD' "$db_password" .env
  set_env 'DB_HOST' "$db_host" .env
  set_env 'WP_ENV' 'production' .env
  set_env 'WP_HOME' "${wp_home%/}" .env
  set_env 'WP_SITEURL' "${wp_home%/}/wp" .env

  for salt in AUTH_KEY SECURE_AUTH_KEY LOGGED_IN_KEY NONCE_KEY AUTH_SALT SECURE_AUTH_SALT LOGGED_IN_SALT NONCE_SALT; do
    set_env "$salt" "$(random_secret)" .env
  done
fi

if confirm 'Enter supported license keys now?' 'no'; then
  for license in ACF_PRO_LICENSE BRICKS_LICENSE_KEY PERFMATTERS_LICENSE_KEY SEOPRESS_LICENSE_KEY; do
    read -r -s -p "${license} (empty to skip): " license_value
    printf '\n'

    if [[ -n "$license_value" ]]; then
      set_env "$license" "$license_value" .env
    fi
  done
fi

printf '\nCreating child theme...\n'
THEME_STAGING="$(mktemp -d 'web/app/themes/.phntz-child.XXXXXX')"
cp -R "$TEMPLATE_DIR/theme/." "$THEME_STAGING/"
escaped_theme_name="$(printf '%s' "$project_title" | sed 's/[\/&]/\\&/g')"

while IFS= read -r -d '' file; do
  sed -i.bak \
    -e "s/{{THEME_NAME}}/${escaped_theme_name}/g" \
    -e "s/{{THEME_SLUG}}/${theme_slug}/g" \
    "$file"
  rm -f "${file}.bak"
done < <(find "$THEME_STAGING" -type f \( -name '*.php' -o -name '*.css' -o -name '*.js' -o -name '*.md' \) -print0)

validate_generated_theme "$THEME_STAGING"
mv "$THEME_STAGING" "$theme_dir"
THEME_STAGING=''

PACKAGE_NAMES=()

for package in "${PACKAGES[@]}"; do
  PACKAGE_NAMES+=("${package%%:*}")
done

"${COMPOSER_COMMAND[@]}" update "${PACKAGE_NAMES[@]}" --with-all-dependencies --no-interaction

# Composer and WordPress.org must never replace a project-named custom theme.
validate_generated_theme "$theme_dir"

initialize_database_default='no'
[[ "$IS_DDEV" == 'yes' ]] && initialize_database_default='yes'

if (( ${#WP_COMMAND[@]} > 0 )) && confirm 'Initialize the WordPress database now?' "$initialize_database_default"; then
  # roots/bedrock already installs the WordPress core through Composer.
  # `wp core install` only creates the site tables and administrator.
  "${WP_COMMAND[@]}" core version >/dev/null \
    || fail 'WordPress core was not found in web/wp after Composer installation.'

  if "${WP_COMMAND[@]}" core is-installed >/dev/null 2>&1; then
    printf 'The WordPress database is already initialized; keeping the existing site and administrator.\n'
  else
    admin_user="$(ask 'Administrator username' "${project_slug}-admin")"
    admin_email="$(ask 'Administrator email' "admin@${project_slug}.test")"
    read -r -s -p 'Administrator password (empty to generate): ' admin_password
    printf '\n'

    if [[ -z "$admin_password" ]]; then
      admin_password="$(openssl rand -base64 24 | tr -d '/+=' | cut -c1-24)"
      printf 'Generated administrator password: %s\n' "$admin_password"
    fi

    install_url="${wp_home:-\$DDEV_PRIMARY_URL}"
    "${WP_COMMAND[@]}" core install \
      --url="$install_url" \
      --title="$project_title" \
      --admin_user="$admin_user" \
      --admin_password="$admin_password" \
      --admin_email="$admin_email" \
      --skip-email
  fi

  validate_generated_theme "$theme_dir"
  "${WP_COMMAND[@]}" theme activate "$theme_slug"
  "${WP_COMMAND[@]}" plugin activate --all

  if [[ "$IS_DDEV" == 'yes' ]] && confirm 'Open wp-admin?' 'yes'; then
    ddev launch /wp/wp-admin/
  fi
else
  printf '\nThe WordPress database was not initialized. Activate theme "%s" after initialization.\n' "$theme_slug"
fi

printf '\nOverlay applied successfully.\n'
